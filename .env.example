# Admin access (use long, unrelated random values)
ADMIN_PASSWORD=replace-with-secure-admin-password
ADMIN_SESSION_TOKEN=replace-with-at-least-32-random-characters

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ajc_media

# Gmail / Nodemailer. Use a Google App Password for SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ajcmedia888@gmail.com
SMTP_PASS=your-16-character-google-app-password
BOOKING_EMAIL_FROM=AJC Media Website <ajcmedia888@gmail.com>
BOOKING_EMAIL_TO=ajcmedia888@gmail.com
